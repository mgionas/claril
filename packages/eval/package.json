{
  "name": "@claril/eval",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "eval": "tsx src/cli.ts",
    "eval:ci": "tsx src/cli.ts --threshold 0.8 --json eval-report.json",
