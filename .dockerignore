# Keep the build context small and never leak secrets / local state into images.

# Dependencies & package-manager state
**/node_modules
.pnpm-store
.pnp
.pnp.js

# Build / cache output
**/.next
**/dist
**/out-tsc
**/.turbo
coverage
*.tsbuildinfo
next-env.d.ts
/tmp

# VCS & CI
.git
.gitignore
.github

# Env / secrets — never copy these into the image
**/.env
**/.env.*
!**/.env.example

# Docker / deploy artifacts (avoid recursive context)
Dockerfile
.dockerignore
docker-compose.yml
docker-compose.*.yml

# Editors & OS cruft
.vscode
.idea
.DS_Store
Thumbs.db

# Logs & debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Project / tooling local state
.archmantic
.claude
.playwright-mcp
.mcp.json
*.png

# Docs are not needed in the runtime image
docs
README.md
CONTRIBUTING.md
AGENTS.md
