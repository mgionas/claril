# Copy to apps/web/.env.local — the app AND Drizzle migrations both read this
# single file (drizzle.config.ts loads it). No separate root .env needed.

# Database — default matches deploy/docker-compose.yml. Use your own Postgres /
# Neon instead by replacing this value.
DATABASE_URL=postgresql://claril:claril@localhost:5432/claril

# Better Auth — generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_URL=http://localhost:3000

# Public canonical site URL for SEO (sitemap, robots, Open Graph, canonical).
# Defaults to https://claril.dev; set this to your own domain when self-hosting.
# NEXT_PUBLIC_SITE_URL=https://your-domain.example

# ---------------------------------------------------------------------------
# Docker self-host (root docker-compose.yml) — see docs/self-hosting.md.
# Copy this file to ./.env (repo root) when running `docker compose up`.
# All of these have defaults in the compose file; override as needed.
# ---------------------------------------------------------------------------
# Credentials for the bundled Postgres `db` service. If you set your own
# DATABASE_URL above to an external Postgres (e.g. Neon), these are unused.
# POSTGRES_USER=claril
# POSTGRES_PASSWORD=claril
# POSTGRES_DB=claril
# Host port mappings (container ports are fixed at 5432 / 3000).
# POSTGRES_PORT=5432
# WEB_PORT=3000
