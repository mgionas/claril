# Copy to `.env` (used by Drizzle migrations) and to `apps/web/.env.local` (the app).
#
# IMPORTANT: DATABASE_URL must be IDENTICAL in both files — they must point at the
# SAME database. Migrations run via `.env`; the app reads `.env.local`. If they
# drift, the app talks to an un-migrated/wrong DB and auth fails with 28P01.

# Database — default matches deploy/docker-compose.yml. Use your own Postgres /
# Neon instead by replacing this in BOTH files.
DATABASE_URL=postgresql://claril:claril@localhost:5432/claril

# Better Auth — generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_URL=http://localhost:3000
